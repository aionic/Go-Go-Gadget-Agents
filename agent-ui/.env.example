# ── agent-ui environment template ──
# Copy to .env.local and fill in. .env.local is gitignored.

# Entra app registration (server-side OAuth: auth-code + PKCE + secret)
AZURE_AD_CLIENT_ID=
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_SECRET=
# Base URL Entra redirects back to (root, registered as a Web reply URL).
REDIRECT_URI=http://localhost:3000

# Foundry hosted agents (server-side proxy via managed identity / az login).
# The chat route invokes the hosted agents over the Responses protocol;
# agent names default in code — override only if the agents were renamed.
FOUNDRY_PROJECT_ENDPOINT=
# PLANNER_AGENT_NAME=ggga-planner
# RESEARCHER_AGENT_NAME=ggga-researcher
# WRITER_AGENT_NAME=ggga-writer
# Set true to run the scripted multi-agent demo with no live backend.
DEMO_MULTI_AGENT=false

# Cosmos feedback persistence (passwordless via DefaultAzureCredential)
COSMOS_ENDPOINT=
COSMOS_DATABASE=agentstate
COSMOS_FEEDBACK_CONTAINER=feedback
